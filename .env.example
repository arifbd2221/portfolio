# ── Copy to .env.local and fill in. Never commit real secrets. ──

# Google Gemini API key — required for the AI chat.
# Get one at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Model the chat uses. Falls back to gemini-2.5-flash if unset.
AI_MODEL=gemini-2.5-flash

# Public site URL — used for absolute metadata / OG image URLs.
# Defaults to http://localhost:3000 in development.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: Upstash Redis for distributed chat rate limiting (Phase 7).
# When these are absent, the app falls back to an in-memory, per-instance
# sliding-window limiter (fine for local/dev, not for multi-instance prod).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Admin panel (git-backed; see admin-build-phases.md) ──

# Auth.js session secret — generate with `npx auth secret` (or openssl rand -base64 32).
AUTH_SECRET=

# GitHub OAuth app for /admin sign-in.
# Create at https://github.com/settings/developers → New OAuth App.
# Callback URL: https://<your-domain>/api/auth/callback/github
# (for local dev: http://localhost:3000/api/auth/callback/github)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# The ONE GitHub username allowed into /admin.
ADMIN_GITHUB_LOGIN=arifbd2221

# Fine-grained PAT (this repo only, Contents: Read & write) — used by the admin
# to commit content changes. Created in Phase A1.
# GITHUB_TOKEN=
# GITHUB_REPO=arifbd2221/portfolio
# GITHUB_BRANCH=main

# Optional: deploy-status pill in the admin after saves.
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
