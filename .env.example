# ── Copy to .env.local and fill in. Never commit real secrets. ──

# Anthropic API key — required for the AI chat (Phase 7).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model the chat uses. Falls back to claude-sonnet-4-6 if unset.
AI_MODEL=claude-sonnet-4-6

# Public site URL — used for absolute metadata / OG image URLs.
# Defaults to http://localhost:3000 in development.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: Upstash Redis for distributed chat rate limiting (Phase 7).
# When these are absent, the app falls back to an in-memory, per-instance
# sliding-window limiter (fine for local/dev, not for multi-instance prod).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
